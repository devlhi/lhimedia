APP_NAME=BotLink
NODE_ENV=development
PORT=3100
# Listener hanya boleh loopback: 127.0.0.1, ::1, atau localhost.
BIND_HOST=127.0.0.1
APP_URL=http://localhost:3100
TELEGRAM_BOT_TOKEN=
# Pilihan: disabled, polling, webhook. Webhook wajib APP_URL HTTPS.
TELEGRAM_MODE=polling
# Buat nilai acak; wajib untuk mode webhook.
TELEGRAM_WEBHOOK_PATH=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_MAX_CONNECTIONS=20
TELEGRAM_COOLDOWN_SECONDS=30
# ID pengguna Telegram numerik yang boleh memakai Veo, dipisahkan koma. Kosong = nonaktif.
TELEGRAM_VEO_ALLOWED_USER_IDS=
# Kontrol biaya Veo Telegram per ID pengguna.
TELEGRAM_VEO_MAX_ACTIVE_PER_USER=1
TELEGRAM_VEO_DAILY_LIMIT=3
TELEGRAM_VEO_STATUS_COOLDOWN_SECONDS=15
ADMIN_USERNAME=admin
# Buat hash: node scripts/hash-password.js "password-minimal-12-karakter"
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
SETTINGS_ENCRYPTION_KEY=
NINE_ROUTER_API_URL=https://api.example.com/v1
NINE_ROUTER_API_KEY=
# Masukkan path dari dokumentasi 9Router, relatif terhadap NINE_ROUTER_API_URL.
NINE_ROUTER_VIDEO_ENDPOINT=videos
MAX_FILE_SIZE_MB=45
DOWNLOAD_TIMEOUT_SECONDS=180
CLEANUP_AFTER_MINUTES=30
DOWNLOAD_CONCURRENCY=2
DOWNLOAD_QUEUE_LIMIT=20
# Opsional: file event keamanan teredaksi dari collector root. Kosong = hanya sinyal aplikasi.
SECURITY_EVENT_FILE=
# Untuk produksi, installer memasang binary yt-dlp terverifikasi ke lokasi ini.
YTDLP_BINARY=
