<%- include('partials/header') %><section class="dashboard"><div class="admin-head"><div class="section-title"><span>DASHBOARD</span><h1>Aktivitas BotLink</h1></div><div><a class="button secondary" href="/admin/telegram">Telegram & Webhook</a> <a class="button" href="/admin/ai">✦ Kelola AI Video</a></div></div><div class="stats"><article><small>Total</small><b><%= stats.total || 0 %></b></article><article><small>Selesai</small><b><%= stats.completed || 0 %></b></article><article><small>Aktif</small><b><%= stats.active || 0 %></b></article><article><small>Antrean</small><b><%= queue.active %>/<%= queue.queued %></b></article></div><div class="table-wrap"><table><thead><tr><th>ID</th><th>Platform</th><th>Sumber</th><th>Status</th><th>Waktu</th></tr></thead><tbody><% downloads.forEach(d => { %><tr><td>#<%= d.id %></td><td><%= d.platform %></td><td><%= d.source %></td><td><span class="status <%= d.status %>"><%= d.status %></span></td><td><%= d.created_at %></td></tr><% }) %><% if(!downloads.length){ %><tr><td colspan="5">Belum ada aktivitas.</td></tr><% } %></tbody></table></div></section><%- include('partials/footer') %>
