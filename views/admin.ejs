<%- include('partials/header') %>
<section class="dashboard">
  <div class="admin-head">
    <div class="section-title"><span>DASHBOARD</span><h1>Resource, Traffic & Keamanan</h1></div>
    <div><a class="button secondary" href="/admin/telegram">Telegram & Webhook</a> <a class="button" href="/admin/ai">✦ Kelola AI Video</a></div>
  </div>

  <div class="stats">
    <article><small>CPU / Load 1m</small><b><%= system.host.cpuCount %> / <%= system.host.loadAverage[0] %></b></article>
    <article><small>RAM VPS</small><b><%= system.host.memory.usedPercent %>%</b><small><%= system.host.memory.usedMb %> / <%= system.host.memory.totalMb %> MB</small></article>
    <article><small>Disk</small><b><%= system.host.disk ? `${system.host.disk.usedPercent}%` : 'N/A' %></b><small><%= system.host.disk ? `${system.host.disk.usedGb} / ${system.host.disk.totalGb} GB` : 'Tidak tersedia' %></small></article>
    <article><small>Memory Aplikasi</small><b><%= system.application.rssMb %> MB</b><small>PID <%= system.application.pid %></small></article>
  </div>

  <div class="monitor-grid">
    <article class="panel">
      <div class="panel-heading"><div><small>RESOURCE VPS</small><h2>Kondisi Server</h2></div><span class="status completed">LIVE</span></div>
      <dl class="details">
        <dt>Uptime VPS</dt><dd><%= Math.floor(system.host.uptimeSeconds / 86400) %> hari <%= Math.floor((system.host.uptimeSeconds % 86400) / 3600) %> jam</dd>
        <dt>Load average</dt><dd><%= system.host.loadAverage.join(' / ') %></dd>
        <dt>RAM tersedia</dt><dd><%= system.host.memory.freeMb %> MB</dd>
        <dt>Uptime aplikasi</dt><dd><%= Math.floor(system.application.uptimeSeconds / 3600) %> jam <%= Math.floor((system.application.uptimeSeconds % 3600) / 60) %> menit</dd>
        <dt>Heap Node.js</dt><dd><%= system.application.heapUsedMb %> / <%= system.application.heapTotalMb %> MB</dd>
      </dl>
    </article>

    <article class="panel">
      <div class="panel-heading"><div><small>TRAFFIC 24 JAM</small><h2>HTTP BotLink</h2></div></div>
      <div class="metric-row"><span>Request</span><b><%= traffic.requests || 0 %></b></div>
      <div class="metric-row"><span>Berhasil (2xx)</span><b><%= traffic.successful || 0 %></b></div>
      <div class="metric-row"><span>Error (4xx/5xx)</span><b><%= traffic.errors || 0 %></b></div>
      <div class="metric-row"><span>Rata-rata respons</span><b><%= traffic.average_ms || 0 %> ms</b></div>
      <div class="metric-row"><span>Traffic masuk/keluar</span><b><%= ((traffic.request_bytes || 0) / 1048576).toFixed(2) %> / <%= ((traffic.response_bytes || 0) / 1048576).toFixed(2) %> MB</b></div>
    </article>
  </div>

  <div class="panel">
    <div class="panel-heading"><div><small>ROUTE TERATAS</small><h2>Traffic Aplikasi</h2></div><span class="muted">Agregat 24 jam</span></div>
    <div class="table-wrap"><table><thead><tr><th>Route</th><th>Request</th><th>Response</th></tr></thead><tbody>
      <% trafficRoutes.forEach(item => { %><tr><td><code><%= item.route %></code></td><td><%= item.requests %></td><td><%= (item.response_bytes / 1048576).toFixed(2) %> MB</td></tr><% }) %>
      <% if (!trafficRoutes.length) { %><tr><td colspan="3">Data traffic akan muncul setelah request diterima.</td></tr><% } %>
    </tbody></table></div>
  </div>

  <div class="panel">
    <div class="panel-heading"><div><small>SECURITY EVENTS</small><h2>Aktivitas Mencurigakan</h2></div><span class="status <%= externalMonitoring ? 'completed' : 'queued' %>"><%= externalMonitoring ? 'VPS + APP' : 'APP ONLY' %></span></div>
    <p class="muted">Sinyal defensif, bukan kesimpulan bahwa VPS sudah diretas. Alamat sumber dipseudonimkan; query, cookie, body, token, dan password tidak disimpan.</p>
    <div class="table-wrap"><table><thead><tr><th>Waktu UTC</th><th>Sumber</th><th>Level</th><th>Kejadian</th><th>Actor</th><th>Path</th></tr></thead><tbody>
      <% securityEvents.forEach(event => { %><tr><td><%= event.created_at %></td><td><%= event.source %></td><td><span class="severity <%= event.severity %>"><%= event.severity %></span></td><td><%= event.summary %></td><td><code><%= event.actor_hash || '-' %></code></td><td class="break"><%= event.path || '-' %></td></tr><% }) %>
      <% if (!securityEvents.length) { %><tr><td colspan="6">Belum ada sinyal keamanan tercatat.</td></tr><% } %>
    </tbody></table></div>
  </div>

  <div class="stats">
    <article><small>Total Download</small><b><%= stats.total || 0 %></b></article>
    <article><small>Selesai</small><b><%= stats.completed || 0 %></b></article>
    <article><small>Aktif</small><b><%= stats.active || 0 %></b></article>
    <article><small>Antrean</small><b><%= queue.active %>/<%= queue.queued %></b></article>
  </div>
  <div class="table-wrap"><table><thead><tr><th>ID</th><th>Platform</th><th>Sumber</th><th>Status</th><th>Waktu</th></tr></thead><tbody>
    <% downloads.forEach(d => { %><tr><td>#<%= d.id %></td><td><%= d.platform %></td><td><%= d.source %></td><td><span class="status <%= d.status %>"><%= d.status %></span></td><td><%= d.created_at %></td></tr><% }) %>
    <% if (!downloads.length) { %><tr><td colspan="5">Belum ada aktivitas.</td></tr><% } %>
  </tbody></table></div>
</section>
<%- include('partials/footer') %>
