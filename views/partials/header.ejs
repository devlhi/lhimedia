<!doctype html><html lang="id"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><meta name="description" content="<%= typeof pageDescription === 'string' ? pageDescription : 'Unduh media publik secara mudah dan bertanggung jawab' %>"><meta name="theme-color" content="#f7fbfd"><meta name="robots" content="<%= typeof robots === 'string' ? robots : (path === '/' ? 'index,follow' : 'noindex,nofollow') %>"><title><%= typeof pageTitle === 'string' ? pageTitle : appName %></title><link rel="icon" href="/favicon.svg" type="image/svg+xml"><% if(typeof appUrl === 'string'){ %><link rel="canonical" href="<%= appUrl %>"><meta property="og:type" content="website"><meta property="og:site_name" content="<%= appName %>"><meta property="og:title" content="<%= typeof pageTitle === 'string' ? pageTitle : appName %>"><meta property="og:description" content="<%= pageDescription %>"><meta property="og:url" content="<%= appUrl %>"><meta name="twitter:card" content="summary"><% } %><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"><link rel="stylesheet" href="/css/app.css"></head><body class="<%= typeof bodyClass === 'string' ? bodyClass : '' %>"><header class="nav"><a href="/" class="brand"><span>↯</span><%= appName %></a><nav><a href="/#cara">Cara Pakai</a><a href="/#platform">Platform</a><% if(path === '/'){ %><a href="/#faq">FAQ</a><% } %><% if(isAdmin){ %><a href="/admin/telegram">Telegram</a><a href="/admin/ai">AI Video</a><a href="/admin">Dashboard</a><form class="nav-form" method="post" action="/admin/logout"><input type="hidden" name="csrf" value="<%= csrfToken || '' %>"><button type="submit">Keluar</button></form><% } else { %><a href="/admin/login">Admin</a><% } %></nav></header><main>
